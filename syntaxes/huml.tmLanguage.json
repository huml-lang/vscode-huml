{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HUML",
  "scopeName": "source.huml",
  "patterns": [
    { "include": "#version-declaration" },
    { "include": "#comments" },
    { "include": "#vector-key" },
    { "include": "#scalar-key" },
    { "include": "#list-item" }
  ],
  "repository": {
    "version-declaration": {
      "name": "meta.version-declaration.huml",
      "match": "^%HUML\\s+\\d+\\.\\d+\\s*(#.*)?$",
      "captures": {
        "0": { "name": "meta.version-declaration.huml" },
        "1": { "name": "comment.line.huml" }
      }
    },
    "comments": {
      "name": "comment.line.huml",
      "match": "#.*$"
    },
    "vector-key": {
      "name": "meta.vector-key.huml",
      "match": "^(\\s*)([\\w_-]+|\"[^\"]*\")\\s*(::)(?:\\s*(#.*)|\\s*(.*))?$",
      "captures": {
        "2": { "name": "entity.name.tag.vector-key.huml" },
        "3": { "name": "punctuation.separator.vector.huml" },
        "4": { "name": "comment.line.huml" },
        "5": { "patterns": [{ "include": "#inline-values" }] }
      }
    },
    "scalar-key": {
      "name": "meta.scalar-key.huml",
      "match": "^(\\s*)([\\w_-]+|\"[^\"]*\")\\s*(:)\\s*(.*)$",
      "captures": {
        "2": { "name": "entity.name.tag.scalar-key.huml" },
        "3": { "name": "punctuation.separator.scalar.huml" },
        "4": { "patterns": [{ "include": "#values" }] }
      }
    },
    "list-item": {
      "name": "meta.list-item.huml",
      "match": "^(\\s*)(-)\\s*(.*)$",
      "captures": {
        "2": { "name": "punctuation.definition.list.huml" },
        "3": { "patterns": [{ "include": "#list-item-values" }] }
      }
    },
    "list-item-values": {
      "patterns": [
        {
          "name": "meta.inline-dict.huml",
          "match": "::\\s*(.*)$",
          "captures": {
            "1": { "patterns": [{ "include": "#inline-values" }] }
          }
        },
        { "include": "#values" }
      ]
    },
    "inline-values": {
      "patterns": [
        {
          "match": "([\\w_-]+|\"[^\"]*\")\\s*:",
          "captures": {
            "1": { "name": "entity.name.tag.inline-key.huml" }
          }
        },
        { "include": "#values" },
        {
          "name": "punctuation.separator.comma.huml",
          "match": ","
        }
      ]
    },
    "values": {
      "patterns": [
        { "include": "#multiline-strings" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#constants" },
        { "include": "#empty-containers" },
        { "include": "#comments" }
      ]
    },
    "multiline-strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.double.huml",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": []
        },
        {
          "name": "string.quoted.triple.backtick.huml",
          "begin": "```", 
          "end": "```",
          "patterns": []
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.huml",
      "begin": "\"",
      "end": "\"",
      "patterns": [{
        "name": "constant.character.escape.huml",
        "match": "\\\\[\"\\\\/bfnrt]"
      }]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b(nan|inf|[-+]inf)\\b",
          "name": "constant.numeric.special.huml"
        },
        {
          "match": "\\b0x[0-9A-Fa-f_]+\\b",
          "name": "constant.numeric.hex.huml"
        },
        {
          "match": "\\b0o[0-7_]+\\b",
          "name": "constant.numeric.octal.huml"
        },
        {
          "match": "\\b0b[01_]+\\b",
          "name": "constant.numeric.binary.huml"
        },
        {
          "match": "\\b-?\\d[\\d_]*(\\.[\\d_]*)?([eE][-+]?[\\d_]+)?\\b",
          "name": "constant.numeric.huml"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.boolean.huml"
        },
        {
          "match": "\\bnull\\b",
          "name": "constant.language.null.huml"
        }
      ]
    },
    "empty-containers": {
      "patterns": [
        {
          "match": "\\[\\]",
          "name": "constant.language.empty.huml"
        },
        {
          "match": "\\{\\}",
          "name": "constant.language.empty.huml"
        }
      ]
    }
  }
}
