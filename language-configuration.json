{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["\"", "\""],
    ["\"\"\"", "\"\"\""],
    ["```", "```"]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*.*::\\s*(#.*)?$",
      "end": "^\\s*$"
    },
    "offSide": true
  },
  "wordPattern": "[a-zA-Z0-9_-]+",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*.*::\\s*(#.*)?$",
    "decreaseIndentPattern": "^\\s*$"
  }
}
